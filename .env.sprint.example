# ---------------------------------------------------------------------------
# Virtual Team Sprint Runner — environment configuration
#
# Copy this file to `.env.sprint` at the repo root and fill in real values.
# The sprint runner loads this file via `loadSprintEnv()` in
# `src/lib/sprint/env.ts`. The runner NEVER reuses production credentials —
# provide a dedicated test MongoDB URI and test-only LLM credentials here.
# ---------------------------------------------------------------------------

# ---- LLM provider ---------------------------------------------------------
# One of: bedrock | openai | anthropic
SPRINT_LLM_PROVIDER=anthropic

# Model identifier understood by the selected provider.
# Examples:
#   bedrock:    anthropic.claude-3-5-sonnet-20241022-v2:0
#   openai:     gpt-4o-mini
#   anthropic:  claude-3-5-sonnet-20241022
SPRINT_LLM_MODEL=claude-3-5-sonnet-20241022

# Per-sprint token budget (positive integer). When exhausted, the sprint
# transitions to `closing`.
SPRINT_TOKEN_BUDGET=500000

# ---- Test App instance ----------------------------------------------------
# Port the isolated test instance of the app listens on.
SPRINT_TEST_PORT=3100

# Full base URL of the test instance. Used by the journey runner and by the
# outbound-host allow-list.
SPRINT_TEST_BASE_URL=http://localhost:3100

# ---- Logging -------------------------------------------------------------
# When "true", raw tool parameters and raw LLM responses are recorded in the
# sprintActionLog. Leave "false" for normal operation.
SPRINT_VERBOSE_LOGS=false

# ---- Sprint-only MongoDB --------------------------------------------------
# MongoDB connection string used ONLY by sprints. MUST NOT point at the
# production cluster — the loader emits a warning if `prod` / `production`
# appears in the URI.
MONGODB_URI=mongodb://localhost:27017/apartment_finder_sprint

# ---- Provider credentials -------------------------------------------------
# Only the block matching SPRINT_LLM_PROVIDER needs to be active. Uncomment
# the relevant lines.

# --- Bedrock ---
# Uses the standard AWS SDK credential chain; AWS_REGION is required.
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- OpenAI ---
# OPENAI_API_KEY=sk-...

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
