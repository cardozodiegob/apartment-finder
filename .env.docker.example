# ----------------------------------------------------------------------------
# Apartment Finder — Docker Compose environment template.
#
# Copy this file to `.env.docker` on the target machine and replace every
# placeholder with the real value. Then bring the stack up with:
#
#   docker compose --env-file .env.docker up -d --build
#
# Nothing here is optional unless explicitly marked OPTIONAL.
# ----------------------------------------------------------------------------

# ---- Web ----

# Exposed host port (change if 3000 is already in use).
WEB_PORT=3000

# Public URL the app will be reachable at (used for canonical, OG, sitemaps).
# Include the scheme + host + port if non-standard. No trailing slash.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- MongoDB (internal) ----

# The root user Mongo creates on first boot. Keep the username simple.
MONGO_ROOT_USERNAME=apartmentfinder
# Generate a strong password, e.g. `openssl rand -base64 32`.
MONGO_ROOT_PASSWORD=change-me-to-a-strong-password
# Application database name.
MONGO_DATABASE=apartmentfinder

# ---- Supabase ----

# From your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1Ni...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1Ni...

# ---- Stripe (payments + Identity / KYC) ----

# Test keys look like `sk_test_...`. Live keys look like `sk_live_...`.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- Email / external services ----

# Resend transactional email. Leave blank to disable email sending.
RESEND_API_KEY=re_...
# Fallback exchange-rate provider (FX endpoint). Leave blank to skip live FX.
EXCHANGE_RATE_API_KEY=

# ---- Cron + webhook secrets ----

# Shared secret the trending / saved-search / SLA-nudge cron endpoints check.
# Generate with `openssl rand -hex 32`.
CRON_SECRET=change-me

# Shared secret the KYC provider webhook must send as `X-Webhook-Secret`.
KYC_WEBHOOK_SECRET=change-me

# ---- Admin bootstrap ----

# On first boot the app auto-creates this admin account if no user exists.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me

# ---- Optional ----

# KYC provider: stripe_identity (default) | sumsub | veriff | stub.
KYC_PROVIDER=stripe_identity

# If you run your own LibreTranslate instance for message translation.
# Leave blank to use the built-in stub (appends a `[lang]` prefix).
LIBRETRANSLATE_URL=
